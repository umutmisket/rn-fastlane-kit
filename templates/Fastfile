# Fastfile — local build & deploy (project-agnostic template)
#
# All project-specific identifiers live in fastlane/project.json (generated by rn-fastlane-kit).
# This file is byte-for-byte identical across projects — nothing to edit here, so a copied
# Fastfile can never leak another project's package name / bundle id / scheme.
#
# ── Version model ────────────────────────────────────────────────────────────
# Marketing version (user-facing, major.minor.patch) = the release label.
#   Single source: package.json -> version. Bumped ONCE PER CYCLE (`fastlane bump`).
#   Standard semver: a minor/major bump zeroes the patch (1.2.4 -> 1.3.0 -> 2.0.0).
#
# Build number (Android versionCode / iOS build) = which upload of that version.
#   AUTOMATIC: highest in the store + 1. Never reset. You never set it by hand.
#   stg and prod ship to the same app, so they share one counter (no collisions).
#   (iOS and Android come from their own store history, so the numbers may differ — fine.)
#
# Environment (stg/prod) = one app, API selected at build time.
#   The lane sets APP_ENV=stg|prod; react-native-dotenv resolves .env/.env.prod and
#   inlines the @env values into the bundle.
#
# Release notes single source: fastlane/release_notes.txt (goes to both Play and TestFlight).
#
# ── Usage ────────────────────────────────────────────────────────────────────
#   fastlane bump                 # new cycle: patch +1 (1.2.3 -> 1.2.4), commit+tag+push
#   fastlane bump bump:minor      # 1.2.4 -> 1.3.0
#   fastlane bump bump:major      # 1.3.5 -> 2.0.0
#   fastlane ios stg    | fastlane ios prod
#   fastlane android stg| fastlane android prod

require "json"
require "shellwords"

REPO_ROOT    = File.expand_path(File.join(__dir__, "..")).freeze
PACKAGE_JSON = File.join(REPO_ROOT, "package.json").freeze

# ── Project config (identifiers) — generated by rn-fastlane-kit ───────────────
CONFIG_PATH = File.join(__dir__, "project.json").freeze
unless File.exist?(CONFIG_PATH)
  UI.user_error!("fastlane/project.json not found. Run: npx github:BNSTECH/rn-fastlane-kit")
end
CONFIG = JSON.parse(File.read(CONFIG_PATH)).freeze

ANDROID_PACKAGE  = CONFIG.fetch("android_package").freeze
IOS_BUNDLE_ID    = CONFIG.fetch("ios_bundle_id").freeze
IOS_TEAM_ID      = CONFIG.fetch("ios_team_id").freeze
IOS_SCHEME       = CONFIG.fetch("ios_scheme").freeze
IOS_WORKSPACE    = CONFIG.fetch("ios_workspace").freeze
PLAY_JSON        = CONFIG.fetch("android_play_json", "fastlane/play-service-account.json").freeze
API_URL_ENV_KEY  = CONFIG["api_url_env_key"] # optional; used only for a log line
ANDROID_LOCALES  = CONFIG.fetch("android_changelog_locales", ["en-US"]).freeze

# For logging only: reads the base URL from the matching .env file so the console shows
# which API a build points at. Falls back to the env name if not configured/found.
def resolve_api_url(env)
  return env unless API_URL_ENV_KEY
  file = env.to_s == "prod" ? ".env.prod" : ".env"
  path = File.join(REPO_ROOT, file)
  (File.read(path)[/^\s*#{Regexp.escape(API_URL_ENV_KEY)}\s*=\s*"?([^"\n]+)"?/, 1]&.strip || env) rescue env
end

# ── Version helpers ───────────────────────────────────────────────────────────

def marketing_version
  json = JSON.parse(File.read(PACKAGE_JSON))
  version = json["version"]
  UI.user_error!("No version found in package.json!") if version.to_s.strip.empty?
  UI.user_error!("package.json version is not major.minor.patch: #{version}") unless version =~ /\A\d+\.\d+\.\d+\z/
  version
end

# Updates the version line in package.json with a minimal diff (keeps formatting).
def write_marketing_version(new_version)
  content = File.read(PACKAGE_JSON)
  updated = content.sub(/("version"\s*:\s*")\d+\.\d+\.\d+(")/, "\\1#{new_version}\\2")
  UI.user_error!("No version line found in package.json!") if updated == content
  File.write(PACKAGE_JSON, updated)
end

# Standard semver bump — minor/major zero the patch.
def bump_version(current, type)
  major, minor, patch = current.split(".").map(&:to_i)
  case type.to_s
  when "major"     then "#{major + 1}.0.0"
  when "minor"     then "#{major}.#{minor + 1}.0"
  when "patch", "" then "#{major}.#{minor}.#{patch + 1}"
  else UI.user_error!("Invalid bump type: '#{type}' (major|minor|patch)")
  end
end

# Derives the build number from the marketing version (iOS build = Android versionCode).
#   prefix    = major*10000 + minor*1000 + patch*100      (7.2.6 -> 72600)
#   iteration = highest store build for this version + 1, else 1  (01..99)
#   build     = prefix + iteration                          (7.2.6 first upload -> 72601)
# existing_codes: build/versionCode list read from the store (any range).
def derive_build_number(existing_codes)
  major, minor, patch = marketing_version.split(".").map(&:to_i)
  UI.user_error!("Version scheme requires single-digit minor and patch (0-9): #{major}.#{minor}.#{patch}") if minor > 9 || patch > 9
  prefix = major * 10000 + minor * 1000 + patch * 100
  in_range = existing_codes.map(&:to_i).select { |c| c > prefix && c < prefix + 100 }
  iteration = in_range.empty? ? 1 : (in_range.max - prefix + 1)
  UI.user_error!("Iteration exceeded 99 for this version (prefix #{prefix}). Do a new patch/minor bump.") if iteration > 99
  prefix + iteration
end

# ── Release-note helpers ──────────────────────────────────────────────────────

def read_release_notes
  path = File.join(__dir__, "release_notes.txt")
  notes = File.exist?(path) ? File.read(path).strip : ""
  UI.user_error!("fastlane/release_notes.txt is empty! Write the release note first.") if notes.empty?
  notes
end

def write_android_changelogs(notes)
  ANDROID_LOCALES.each do |locale|
    dir = File.join(__dir__, "metadata", "android", locale, "changelogs")
    FileUtils.mkdir_p(dir)
    File.write(File.join(dir, "default.txt"), notes)
  end
end

# RN native build state (.cxx + prefab build + android/.gradle) is not fully cleaned by
# `gradle clean` and can cause "undefined symbol" linker errors (e.g. reanimated<->worklets).
# Reset these dirs + stop the daemon before a release (native rebuilds from scratch,
# ~5 min but reliable). This is the automated form of the manual "clear cache + gradlew clean".
def clean_android_native
  UI.message("Cleaning Android native cache (.cxx/build/.gradle) — prevents stale linker errors.")
  sh("cd #{REPO_ROOT.shellescape}/android && ./gradlew --stop", log: false) rescue nil
  %w[
    android/.gradle
    android/build
    android/app/.cxx
    android/app/build
    node_modules/react-native-reanimated/android/.cxx
    node_modules/react-native-reanimated/android/build
    node_modules/react-native-worklets/android/.cxx
    node_modules/react-native-worklets/android/build
  ].each { |p| FileUtils.rm_rf(File.join(REPO_ROOT, p)) }
end

# The @env values are inlined into the bundle by babel at build time; Metro's transform
# cache does NOT notice the env change and may inline the old values into prod after a stg
# build. Clear the cache before bundling (critical when switching between stg/prod).
def clear_metro_cache
  tmp = ENV["TMPDIR"] || "/tmp"
  Dir.glob(File.join(tmp, "metro-*")).each { |p| FileUtils.rm_rf(p) }
  Dir.glob(File.join(tmp, "haste-map-*")).each { |p| FileUtils.rm_rf(p) }
  UI.message("Metro cache cleared.")
end

# ── Git hygiene ───────────────────────────────────────────────────────────────
before_all do
  ensure_git_status_clean   # never release with uncommitted changes
  git_pull                  # work on up-to-date code
end

# ── Marketing version bump (once per cycle) ───────────────────────────────────
desc "Bump package.json marketing version + commit + tag + push (bump:major|minor|patch)"
lane :bump do |options|
  type  = options[:bump] || "patch"
  old_v = marketing_version
  new_v = bump_version(old_v, type)

  write_marketing_version(new_v)
  git_commit(path: ["package.json"], message: "chore(release): v#{new_v}")
  add_git_tag(tag: "v#{new_v}")
  push_to_git_remote

  UI.success("🔖 #{old_v} -> #{new_v}")
  UI.message("Next: fastlane ios stg|prod  /  fastlane android stg|prod")
end

# ── Shared (private) build+upload flows ───────────────────────────────────────

private_lane :android_ship do |options|
  env    = options[:env]
  track  = options[:track]
  status = options[:release_status] || "draft"

  version_name = marketing_version
  notes = read_release_notes
  write_android_changelogs(notes)

  # Collect existing versionCodes across all Play tracks, derive the build from the version.
  existing = []
  %w[internal alpha beta production].each do |t|
    begin
      existing += google_play_track_version_codes(
        package_name: ANDROID_PACKAGE, track: t, json_key: PLAY_JSON
      )
    rescue => e
      UI.message("Track '#{t}' unreadable (#{e.message}) — skipping.")
    end
  end
  build = derive_build_number(existing)

  ENV["APP_ENV"] = env
  UI.message("Android #{env}: v#{version_name} (build #{build}) -> #{resolve_api_url(env)}")

  clean_android_native
  clear_metro_cache
  gradle(task: "clean", project_dir: "android")
  gradle(
    task: "bundle",
    build_type: "Release",
    project_dir: "android",
    properties: { "appVersionCode" => build, "appVersionName" => version_name }
  )

  upload_to_play_store(
    track: track,
    # "Release name" shown in Play Console, e.g. "72601 (7.2.6)".
    # (Label only; the versionCode is already inside the AAB.)
    version_name: "#{build} (#{version_name})",
    aab: "android/app/build/outputs/bundle/release/app-release.aab",
    release_status: status,
    skip_upload_apk: true,
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true,
    skip_upload_changelogs: false
  )

  UI.success("✅ Android #{env}: v#{version_name} (#{build}) -> #{track}/#{status}")
end

private_lane :ios_ship do |options|
  env = options[:env]

  version_name = marketing_version
  notes = read_release_notes

  api_key = app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"] || "fastlane/appstore_api_key.p8",
    in_house: false
  )

  # Highest TestFlight build for this marketing version, derive the build from the version.
  latest = latest_testflight_build_number(
    api_key: api_key,
    app_identifier: IOS_BUNDLE_ID,
    version: version_name,
    initial_build_number: 0
  )
  build = derive_build_number(latest.to_i > 0 ? [latest] : [])

  ENV["APP_ENV"] = env
  UI.message("iOS #{env}: v#{version_name} (build #{build}) -> #{resolve_api_url(env)}")
  clear_metro_cache

  # Create/download an App Store distribution profile that embeds our local distribution cert.
  # force: true → regenerate with current certs each time. We use the installed profile with
  # MANUAL signing at export (so cloud/automatic signing can't cause an authorization error).
  get_provisioning_profile(
    api_key: api_key,
    app_identifier: IOS_BUNDLE_ID,
    force: true
  )
  profile_name = lane_context[SharedValues::SIGH_NAME]

  # Pass -allowProvisioningUpdates + API-key auth to ARCHIVE manually (gym doesn't add it).
  asc_key_abs = File.expand_path(ENV["ASC_KEY_PATH"] || "fastlane/fastlane-api-key.p8", REPO_ROOT)
  archive_auth = "-allowProvisioningUpdates " \
                 "-authenticationKeyPath #{asc_key_abs.shellescape} " \
                 "-authenticationKeyID #{ENV['ASC_KEY_ID']} " \
                 "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"

  build_app(
    workspace: IOS_WORKSPACE,
    scheme: IOS_SCHEME,
    export_method: "app-store",
    clean: true,
    output_directory: "ios/build",
    output_name: "#{IOS_SCHEME}.ipa",
    # Override marketing version + build number at build time without touching pbxproj.
    xcargs: "MARKETING_VERSION=#{version_name} CURRENT_PROJECT_VERSION=#{build} #{archive_auth}",
    # Manual signing + our profile → no cloud signing attempted, uses the local cert.
    export_options: {
      method: "app-store",
      signingStyle: "manual",
      teamID: IOS_TEAM_ID,
      provisioningProfiles: { IOS_BUNDLE_ID => profile_name }
    }
  )

  upload_to_testflight(
    api_key: api_key,
    changelog: notes,
    distribute_external: false,
    skip_waiting_for_build_processing: false
  )

  UI.success("✅ iOS #{env}: v#{version_name} (#{build}) on TestFlight. (for prod, submit to the App Store from App Store Connect)")
end

# ─────────────────────────────────────────────────────────────────────────────

default_platform(:android)

platform :android do
  desc "Build with staging API + Play internal (released to testers) + release note"
  lane :stg do
    # completed: the internal track has no Google review; the build reaches testers immediately.
    android_ship(env: "stg", track: "internal", release_status: "completed")
  end

  desc "Build with prod API + Play production (draft) + release note"
  lane :prod do
    android_ship(env: "prod", track: "production", release_status: "draft")
  end
end

platform :ios do
  desc "Build with staging API + TestFlight + release note"
  lane :stg do
    ios_ship(env: "stg")
  end

  desc "Build with prod API + TestFlight (App Store ready) + release note"
  lane :prod do
    ios_ship(env: "prod")
  end
end
