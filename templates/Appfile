# Appfile — reads identifiers from fastlane/project.json (generated by rn-fastlane-kit).
# No hardcoded ids here, so this file is identical across projects.
require "json"

_cfg = JSON.parse(File.read(File.join(__dir__, "project.json")))

for_platform :android do
  package_name(_cfg.fetch("android_package"))
  json_key_file(_cfg.fetch("android_play_json", "fastlane/play-service-account.json"))
end

for_platform :ios do
  app_identifier(_cfg.fetch("ios_bundle_id"))
  # No apple_id / team ID needed here: we use an App Store Connect API Key (.p8) in the Fastfile.
end
