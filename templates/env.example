# fastlane/.env — secrets for fastlane (NEVER committed; must be gitignored).
# Copy to fastlane/.env and fill in real values, or let fastlane-kit/setup.js generate it.

# ── App Store Connect API Key (iOS) ──────────────────────────────────────────
# App Store Connect > Users and Access > Integrations > App Store Connect API
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Path to the AuthKey_XXXXXXXXXX.p8 you downloaded (relative to repo root)
ASC_KEY_PATH=fastlane/appstore_api_key.p8

# ── Android release signing (Google Play) ────────────────────────────────────
# build.gradle reads these via System.getenv; fastlane loads fastlane/.env automatically.
# IMPORTANT: no inline comments after the value — just the value.
# Full path to the .jks/.keystore file
ANDROID_KEYSTORE_FILE=/absolute/path/to/release.keystore
ANDROID_KEYSTORE_PASSWORD=xxxxxxxx
ANDROID_KEY_ALIAS=xxxxxxxx
ANDROID_KEY_PASSWORD=xxxxxxxx
